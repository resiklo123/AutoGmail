generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PostStatus {
  PROCESSING
  DRAFT_READY
  DRAFT
  POSTED
  ARCHIVED
  FAILED
}

model Post {
  id                   String     @id @default(cuid())
  slug                 String     @unique
  machine              String
  machineFamily        String
  machineModel         String?
  topic                String
  location             String?
  platforms            String[]
  status               PostStatus @default(PROCESSING)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @default(now()) @updatedAt
  libraryFolderId      String?
  libraryFolderUrl     String?
  byDateShortcutUrl    String?
  byMachineShortcutUrl String?
  assets               Asset[]
  drafts               Draft[]
  logs                 PostingLog[]
}

model Asset {
  id            String   @id @default(cuid())
  postId        String
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  driveFileId   String
  originalName  String
  finalName     String
  mimeType      String
  size          BigInt?
  webViewLink   String?
  thumbnailLink String?
  createdAt     DateTime @default(now())
}

model Draft {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform    String
  title       String?
  caption     String?
  hashtags    String?
  description String?
  version     Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt
}

model PostingLog {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform  String
  postedUrl String?
  postedAt  DateTime?
  postedBy  String?
  notes     String?
  updatedAt DateTime  @default(now()) @updatedAt

  @@unique([postId, platform])
}

model MachineModelOption {
  id        String   @id @default(cuid())
  family    String
  model     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([family, model])
}

model UploadBatch {
  id              String          @id @default(cuid())
  batchCode       String          @unique
  uploadedAt      DateTime        @default(now())
  uploadedBy      String?
  machineFamily   String          @default("Unknown")
  machineModel    String          @default("Unknown")
  topic           String          @default("Uncategorized")
  location        String          @default("Unknown")
  metadataSource  String          @default("DEFAULT")
  reviewStatus    String          @default("NEEDS_REVIEW")
  aiConfidence    Float?
  fileCount       Int             @default(0)
  driveFolderId   String?
  driveFolderUrl  String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assets          IncomingAsset[]
}

model IncomingAsset {
  id            String      @id @default(cuid())
  batchId       String
  batch         UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  driveFileId   String
  originalName  String
  storedName    String
  mimeType      String?
  sizeBytes     BigInt?
  webViewLink   String?
  thumbnailLink String?
  uploadStatus  String      @default("UPLOADED")
  errorMessage  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}